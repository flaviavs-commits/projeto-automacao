APP_NAME=bot-multiredes
APP_ENV=development
APP_PORT=8000
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/bot_multiredes
REDIS_URL=redis://localhost:6379/0
META_ENABLED=true
META_VERIFY_TOKEN=change-me
META_ACCESS_TOKEN=
META_GRAPH_BASE_URL=https://graph.facebook.com
META_AUTH_BASE_URL=https://www.facebook.com
META_API_VERSION=v23.0
META_WHATSAPP_PHONE_NUMBER_ID=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
META_APP_ID=
META_APP_SECRET=
META_OAUTH_REDIRECT_URI=
META_OAUTH_SCOPES=public_profile,pages_show_list,pages_read_engagement,instagram_basic,instagram_content_publish,business_management,whatsapp_business_management,whatsapp_business_messaging
OAUTH_STATE_SECRET=
OAUTH_STATE_TTL_SECONDS=600
TOKEN_ENCRYPTION_SECRET=
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
TIKTOK_ENABLED=true
TIKTOK_API_BASE_URL=https://open.tiktokapis.com
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
LLM_ENABLED=true
LLM_PROVIDER=ollama
LLM_BASE_URL=http://127.0.0.1:11434
LLM_MODEL=qwen2.5:1.5b-instruct
LLM_TEMPERATURE=0.1
LLM_MAX_OUTPUT_TOKENS=220
LLM_TIMEOUT_SECONDS=90
LLM_NUM_CTX=1024
LLM_NUM_THREAD=4
LLM_KEEP_ALIVE=10m
LLM_CONTEXT_MESSAGES=12
LLM_DOMAIN_LOCK=true
LLM_DOMAIN_DESCRIPTION=fc vip estudio fotografia video agendamento
LLM_KNOWLEDGE_PATH=app/prompts/studio_agendamento.md
LLM_TEST_MODELS=qwen2.5:1.5b-instruct,qwen2.5:7b-instruct,mistral-nemo:12b-instruct
LLM_QUALITY_RETRY_ENABLED=true
LLM_QUALITY_FALLBACK_MODEL=qwen2.5:1.5b-instruct
LLM_QUALITY_MIN_CHARS=90
LOCAL_STORAGE_PATH=storage
LOG_LEVEL=INFO
