APP_NAME=bot-multiredes
APP_ENV=development
APP_PORT=8000
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/bot_multiredes
REDIS_URL=redis://localhost:6379/0
META_ENABLED=true
META_VERIFY_TOKEN=change-me
META_ACCESS_TOKEN=
META_GRAPH_BASE_URL=https://graph.facebook.com
META_AUTH_BASE_URL=https://www.facebook.com
META_API_VERSION=v23.0
META_WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_PROVIDER=evolution
WHATSAPP_GATEWAY_BASE_URL=
WHATSAPP_GATEWAY_API_KEY=
WHATSAPP_SESSION_NAME=
EVOLUTION_API_BASE_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
META_APP_ID=
META_APP_SECRET=
META_OAUTH_REDIRECT_URI=
META_OAUTH_SCOPES=public_profile,pages_show_list,pages_read_engagement,instagram_basic,instagram_content_publish,business_management,whatsapp_business_management,whatsapp_business_messaging
OAUTH_STATE_SECRET=
OAUTH_STATE_TTL_SECONDS=600
TOKEN_ENCRYPTION_SECRET=
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
TIKTOK_ENABLED=true
TIKTOK_API_BASE_URL=https://open.tiktokapis.com
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
LLM_ENABLED=true
LLM_PROVIDER=ollama
LLM_BASE_URL=http://127.0.0.1:11434
LLM_MODEL=qwen2.5:0.5b-instruct
LLM_TEMPERATURE=0.2
LLM_MAX_OUTPUT_TOKENS=160
LLM_TIMEOUT_SECONDS=45
LLM_NUM_CTX=768
LLM_NUM_THREAD=2
LLM_KEEP_ALIVE=8m
LLM_BUSINESS_OPEN_HOUR=9
LLM_BUSINESS_CLOSE_HOUR=22
LLM_CONTEXT_MESSAGES=5
LLM_OFFTOPIC_TOLERANCE_TURNS=2
LLM_DOMAIN_LOCK=true
LLM_DOMAIN_DESCRIPTION=fc vip estudio fotografia video agendamento
LLM_KNOWLEDGE_PATH=app/prompts/studio_agendamento.md
LLM_KNOWLEDGE_MAX_CHARS=5000
LLM_KNOWLEDGE_MAX_SECTIONS=3
LLM_PROMPT_MAX_CONTEXT_CHARS=700
LLM_MAX_KEY_MEMORIES=12
LLM_TEST_MODELS=qwen2.5:0.5b-instruct,qwen2.5:1.5b-instruct
LLM_QUALITY_RETRY_ENABLED=true
LLM_QUALITY_FALLBACK_MODEL=qwen2.5:1.5b-instruct
LLM_QUALITY_MIN_CHARS=80
LOCAL_STORAGE_PATH=storage
LOG_LEVEL=INFO
MESSAGE_RETENTION_MAX_PER_CONVERSATION=5
CONVERSATION_AUTO_CLOSE_AFTER_MINUTES=60
TEMP_CONTACT_TTL_MINUTES=120
FCVIP_PARTNER_API_ENABLED=true
FCVIP_PARTNER_API_BASE_URL=
FCVIP_PARTNER_API_KEY=
FCVIP_PARTNER_API_TIMEOUT_SECONDS=12
FCVIP_PARTNER_API_PAGE_SIZE=50
FCVIP_PARTNER_API_LEADS_MAX_PAGES=3
